// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  HOST
  GUEST 
}

enum ListingType {
  APARTMENT
  HOUSE
  VILLA
  CABIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  username  String    @unique
  password  String
  phone     String
  role      Role      @default(GUEST)
  avatar    String?
  avatarPublicId String?
  bio       String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  resetToken String?
  resetTokenExpiry DateTime?
  listings  Listing[]
  bookings  Booking[]
  
}

model Listing {
  id            Int         @id @default(autoincrement())
  title         String
  description   String
  location      String
  pricePerNight Float
  guests        Int
  type          ListingType
  amenities     String[]
  rating        Float?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  hostId        Int
  host          User        @relation(fields: [hostId], references: [id], onDelete: Cascade)
  bookings      Booking[]
  photos        ListingPhoto[]

  @@index([location])
  @@index([pricePerNight])
}

model ListingPhoto {
  id        Int     @id @default(autoincrement())
  url       String
  publicId  String
  listingId Int
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Booking {
  id         Int           @id @default(autoincrement())
  checkIn    DateTime
  checkOut   DateTime
  totalPrice Float
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  guestId    Int
  listingId  Int
  guest      User          @relation(fields: [guestId], references: [id], onDelete: Cascade)
  listing    Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
}
